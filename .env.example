APP_ENV=dev

CORS_ALLOWED_ORIGINS=["*"]

MONGO_URI=mongodb://mongo:27017
MONGO_DB=voice_chat

JWT_SECRET=supersecret
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Email
EMAIL_PROVIDER=smtp
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# If you want MinIO later:
#STORAGE_PROVIDER=local
STORAGE_PROVIDER=s3
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=voicechat
S3_REGION=us-east-1

# Rate Limit
#RATE_LIMIT_STORAGE_URI=async+memory://
RATE_LIMIT_STORAGE_URI=async+redis://redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
EMAIL_QUEUE_NAME=email.send

REDIS_URL=redis://redis:6379/0

#PRESENCE_BACKEND=memory
PRESENCE_BACKEND=redis
PRESENCE_KEY_PREFIX=presence

#SOCKETIO_QUEUE_BACKEND=memory
SOCKETIO_QUEUE_BACKEND=redis
SOCKETIO_REDIS_URL=redis://redis:6379/0